{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitsDisabled",
    ":disableDependencyDashboard"
  ],
  "packageRules": [
    {
      "description": "",
      "matchPackageNames": ["*"],
      "enabled": false
    },
    {
      "matchDepTypes": ["action"],
      "pinDigests": true,
      "enabled": true
    },
    {
      "description": "",
      "matchDatasources": ["github-runners"],
      "enabled": true
    }
  ]
}
